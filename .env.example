APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

AI_ASSISTANT_FS_TOOLS_ENABLED=true
AI_ASSISTANT_FS_ALLOW_ANY_PATH=true
AI_ASSISTANT_FS_ROOTS=/home/maikol1/agentic-v.2,/tmp
AI_ASSISTANT_FS_MAX_READ_CHARS=200000
AI_ASSISTANT_FS_MAX_WRITE_CHARS=400000
AI_ASSISTANT_FS_MAX_TOOL_ROUNDS=8
AI_ASSISTANT_FS_MAX_TOOL_ROUNDS_HARD_CAP=24
AI_ASSISTANT_FS_SHELL_ENABLED=false
AI_ASSISTANT_FS_SHELL_ALLOW_ANY_COMMAND=false
AI_ASSISTANT_FS_SHELL_ALLOWED_PREFIXES="php artisan,npm run,composer,git status,git diff,ls,cat,rg"
AI_ASSISTANT_FS_SHELL_BLOCKED_PATTERNS="php artisan migrate:fresh,php artisan migrate:refresh,php artisan db:wipe,php artisan schema:drop,php artisan migrate:reset"
AI_ASSISTANT_FS_SHELL_TIMEOUT_SECONDS=30
AI_ASSISTANT_FS_SHELL_MAX_OUTPUT_CHARS=12000
AI_ASSISTANT_WEB_SEARCH_ENABLED=false
AI_ASSISTANT_WEB_SEARCH_API_KEY=
AI_ASSISTANT_WEB_SEARCH_BASE_URL=https://api.tavily.com
AI_ASSISTANT_WEB_SEARCH_ENDPOINT=/search
AI_ASSISTANT_WEB_SEARCH_TIMEOUT_SECONDS=20
AI_ASSISTANT_WEB_SEARCH_MAX_RESULTS=5
AI_ASSISTANT_WEB_SEARCH_ALLOWED_DOMAINS=
AI_ASSISTANT_WEB_SEARCH_BLOCKED_DOMAINS="localhost,127.0.0.1,0.0.0.0,169.254.169.254"
AI_ASSISTANT_WEB_SEARCH_REQUIRE_CITATIONS=true
AI_ASSISTANT_TS_CHECK_ON_CODING=true
AI_ASSISTANT_TS_CHECK_COMMAND="npm run types -- --pretty false"
AI_ASSISTANT_TS_CHECK_TIMEOUT_SECONDS=120
AI_ASSISTANT_TS_CHECK_MAX_OUTPUT_CHARS=24000
AI_ASSISTANT_UI_EXPOSE_THINKING=false


APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# DB_SOCKET=/var/run/mysqld/mysqld.sock
DB_DATABASE=atlasai
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

AI_ASSISTANT_OLLAMA_BASE_URL=http://127.0.0.1:11434
AI_ASSISTANT_REQUEST_TIMEOUT=300
AI_ASSISTANT_MODEL_PLANNING=glm-5:cloud
AI_ASSISTANT_MODEL_CODING=qwen3-coder-next:cloud
AI_ASSISTANT_MODEL_EMBEDDING=qwen3-embedding:0.6b
AI_ASSISTANT_RETRIEVAL_ENABLED=true
AI_ASSISTANT_MAX_CONTEXT_CHUNKS=4
AI_ASSISTANT_MAX_INDEX_FILES=40
AI_ASSISTANT_MAX_FILE_CHARS=2400
AI_ASSISTANT_CHUNK_SIZE=900
AI_ASSISTANT_CHUNK_OVERLAP=180
AI_ASSISTANT_INDEX_CACHE_TTL=86400
AI_ASSISTANT_RETRIEVAL_LAZY_WARM=true
AI_ASSISTANT_RETRIEVAL_LAZY_WARM_MAX_SECONDS=8
AI_ASSISTANT_FS_TOOLS_ENABLED=true
AI_ASSISTANT_FS_ALLOW_ANY_PATH=true
AI_ASSISTANT_FS_ROOTS=/home/maikol1/agentic-v.2,/tmp
AI_ASSISTANT_FS_MAX_READ_CHARS=200000
AI_ASSISTANT_FS_MAX_WRITE_CHARS=400000
AI_ASSISTANT_FS_MAX_TOOL_ROUNDS=8
AI_ASSISTANT_FS_MAX_TOOL_ROUNDS_HARD_CAP=24
AI_ASSISTANT_FS_MAX_SEARCH_RESULTS=60
AI_ASSISTANT_FS_MAX_SEARCH_FILE_BYTES=300000
AI_ASSISTANT_TASK_RUNS_AUTONOMOUS_ENABLED=true
AI_ASSISTANT_TASK_RUNS_MAX_AUTONOMOUS_STEPS=10
AI_ASSISTANT_TASK_RUNS_MAX_ATTEMPTS_PER_STEP=3
AI_ASSISTANT_PIPELINE_ENABLED=true
AI_ASSISTANT_PIPELINE_VALIDATION_COMMANDS="npm run types,php artisan migrate --pretend --force"
AI_ASSISTANT_PIPELINE_VALIDATION_TIMEOUT_SECONDS=180
AI_ASSISTANT_PIPELINE_VALIDATION_MAX_OUTPUT_CHARS=16000
